{
  "name": "supplysync-workspace",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "frontend",
    "apps/mobile",
    "packages/core",
    "packages/ui"
  ],
  "scripts": {
    "web:start": "npm run start --workspace frontend",
    "web:build": "npm run build --workspace frontend",
    "mobile:start": "npm run start --workspace apps/mobile",
    "web:test": "npm run test:ci --workspace frontend",
    "mobile:web:build": "npm run build:web --workspace apps/mobile",
    "core:validate": "npm run validate --workspace @supplysync/core",
    "ui:validate": "npm run validate --workspace @supplysync/ui",
    "validate": "npm run core:validate && npm run ui:validate && npm run web:build && npm run web:test && npm run mobile:web:build"
  }
}
