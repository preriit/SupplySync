# Example Nginx protection for SupplySync admin APIs.
# Include this inside your existing `server { ... }` block.
#
# Adjust allowlisted IPs before enabling.

# Optional global API rate limits (define once in http{} context)
# limit_req_zone $binary_remote_addr zone=api_login_limit:10m rate=10r/m;

location /api/admin/ {
    # Optional IP allowlist (recommended for backoffice access)
    allow 127.0.0.1;
    # allow <your-office-public-ip>;
    # allow <your-vpn-egress-ip>;
    deny all;

    # Optional basic auth layer (defense in depth)
    # auth_basic "SupplySync Admin API";
    # auth_basic_user_file /etc/nginx/.htpasswd_admin_api;

    proxy_pass http://127.0.0.1:8001;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# Optional: protect admin UI routes similarly
location /admin/ {
    allow 127.0.0.1;
    # allow <your-office-public-ip>;
    # allow <your-vpn-egress-ip>;
    deny all;

    proxy_pass http://127.0.0.1:3000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
